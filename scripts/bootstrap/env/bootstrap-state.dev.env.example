# Copy to bootstrap-state.dev.env (gitignored) and run: make bootstrap-state-dev
# Storage account names must be globally unique (3–24 lowercase alphanumerics).

RESOURCE_GROUP=rg-platform-bootstrap-dev
LOCATION=koreacentral
STORAGE_ACCOUNT=stplatformbootstrapdev

CONTAINER_NAME=tfstate
SKU=Standard_LRS

TAG_ENVIRONMENT=dev
TAG_OWNER=platform-team
TAG_COST_CENTER=infrastructure
