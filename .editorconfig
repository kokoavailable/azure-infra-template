# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{tf,hcl,pkr.hcl,tftest.hcl,tftpl,sh,yml,yaml,json}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.py]
indent_style = space
indent_size = 4

[*.go]
indent_style = tab

[*.{drawio,png,jpg,jpeg,svg}]
insert_final_newline = false
trim_trailing_whitespace = false
